# 智析实验平台 - 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ==================== 环境配置 ====================
# 可选值: development, production, testing
ENVIRONMENT=development

# ==================== 日志配置 ====================
LOG_LEVEL=INFO

# ==================== API服务配置 ====================
API_HOST=0.0.0.0
API_PORT=8000

# ==================== CORS配置 ====================
# 生产环境应限制为实际的前端域名，多个域名用逗号分隔
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ==================== AI助手配置 ====================
# 选择使用哪个API（true使用学校API，false使用自定义API）
USE_SCHOOL_API=false

# 自定义API配置（Deepseek等）
AI_API_BASE_URL=https://api.deepseek.com
AI_API_KEY=your_api_key_here
AI_MODEL=deepseek-chat
AI_MAX_TOKENS=2000

# 学校API配置（如果USE_SCHOOL_API=true）
SCHOOL_API_BASE_URL=https://llm-gw.bupt.edu.cn/v1
SCHOOL_API_KEY=your_school_api_key_here
SCHOOL_API_MODEL=deepseek-v3-671b-64k

# ==================== PySR配置 ====================
PYSR_ITERATIONS=100
PYSR_POPULATION_SIZE=20
PYSR_MAX_SIZE=20

# ==================== 前端配置 ====================
# 前端开发服务器配置（用于Vite代理）
VITE_API_BASE_URL_1=http://localhost:8000
VITE_API_BASE_URL_2=http://localhost:8001

