# GuideLab production template
# Copy this file to .env on the server and fill in real values.

DEBUG=false

# Frontend/backend domains that may call the API.
# Use JSON-list syntax because pydantic-settings parses this as List[str].
CORS_ORIGINS=["http://localhost:5173","http://ruixi.tech","https://ruixi.tech","http://www.ruixi.tech","https://www.ruixi.tech"]
CORS_ALLOW_CREDENTIALS=true

# AI 与 compute 两个服务必须使用完全相同的随机值。
# 生产服务器生成：openssl rand -hex 32
CLASSROOM_SESSION_SECRET=change-me-to-the-same-random-secret-on-both-services
CLASSROOM_SESSION_COOKIE_NAME=guidelab_classroom_session
CLASSROOM_SESSION_TTL_SECONDS=28800
CLASSROOM_SESSION_COOKIE_SECURE=false
CLASSROOM_SESSION_COOKIE_SAMESITE=lax

# Frontend build-time API addresses.
# If Nginx proxies /api -> compute and /ai -> AI assistant, use:
# VITE_COMPUTE_API_URL=https://your-domain.example.com/api
# VITE_AI_API_URL=https://your-domain.example.com/ai
VITE_COMPUTE_API_URL=
VITE_AI_API_URL=

# AI provider. Fill in one valid key.
USE_SCHOOL_API=false
AI_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_API_KEY=
AI_API_MODEL=qwen3-max
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.7
AI_TIMEOUT=30
AI_ENABLE_THINKING=true
AGENT_ENABLE_TOOLS=true
AGENT_MAX_TOOL_ROUNDS=3
RAG_ENABLE_TOOL=false
RAG_COLLECTION_NAME=physics_knowledge_v2
RAG_EMBEDDING_MODEL=BAAI/bge-m3
RAG_RERANK_MODEL=BAAI/bge-reranker-v2-m3
RAG_RETRIEVAL_MODE=hybrid_rerank
RAG_PARENT_CHUNK_SIZE=1200
RAG_CHILD_CHUNK_SIZE=350
RAG_CHILD_CHUNK_OVERLAP=60
RAG_MODEL_MAX_LENGTH=1024
RAG_EMBED_BATCH_SIZE=4
RAG_DENSE_CANDIDATES=24
RAG_SPARSE_CANDIDATES=24
RAG_FUSION_CANDIDATES=20
RAG_RERANK_ENABLED=true
RAG_RERANK_THRESHOLD=0.05
RAG_TOP_K=6
RAG_MAX_CONCURRENT_SEARCHES=2
HF_HOME=/var/lib/guidelab-ai/knowledge_base/model_cache
HF_HUB_CACHE=/var/lib/guidelab-ai/knowledge_base/model_cache/hub
TOKENIZERS_PARALLELISM=false
AI_MAX_CONCURRENT_REQUESTS=16
AI_MAX_CONCURRENT_REQUESTS_PER_SESSION=1
AI_MAX_REQUESTS_PER_MINUTE_PER_SESSION=20

# Independent service processes. COMPUTE_SERVICE_URL is the internal address
# used by AI Agent tools when they query a PySR task; it is not a browser URL.
COMPUTE_SERVICE_HOST=0.0.0.0
COMPUTE_SERVICE_PORT=8000
COMPUTE_SERVICE_URL=http://127.0.0.1:8000
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8001

# PySR scheduler profile for a 16-core / 32-GB compute server.
# Four isolated tasks x three Julia cores = 12 cores, leaving four cores for
# FastAPI, plotting, file parsing, and the operating system.
PYSR_MAX_CONCURRENT_TASKS=4
PYSR_PROCS_PER_TASK=3
PYSR_POPULATIONS_PER_TASK=9
PYSR_PARALLELISM=multithreading
PYSR_MAX_QUEUED_TASKS=120
PYSR_MAX_RUNNING_TASKS_PER_SESSION=1
PYSR_MAX_QUEUED_TASKS_PER_SESSION=2
PYSR_TASK_TIMEOUT_SECONDS=1800
PYSR_TASK_RETENTION_SECONDS=21600
PYSR_MAX_NITERATIONS=300
PYSR_MAX_POPULATION_SIZE=60
PYSR_MAX_EXPRESSION_SIZE=40
PYSR_MAX_BATCH_SIZE=1000

# Prevent BLAS libraries inside each worker from creating extra thread pools.
JULIA_NUM_THREADS=3
OMP_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1
MKL_NUM_THREADS=1

# Upload and output paths. Relative paths are resolved from the project root.
MAX_FILE_SIZE=10485760
DATA_DIR=data
UPLOADS_DIR=data/uploads
OUTPUTS_DIR=data/outputs
PYSR_OUTPUT_DIR=pysr_module/output
PYSR_PLOTS_DIR=pysr_module/output/plots

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=logs/app.log
