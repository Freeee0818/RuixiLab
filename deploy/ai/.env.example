# AI API (chat + RAG + Agent)
DEBUG=false
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8001

# 必须与 compute 服务完全一致。生成：openssl rand -hex 32
CLASSROOM_SESSION_SECRET=
CLASSROOM_SESSION_COOKIE_SECURE=true
CLASSROOM_SESSION_COOKIE_SAMESITE=lax

USE_SCHOOL_API=false
AI_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_API_KEY=
AI_API_MODEL=qwen3-max
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.7
AI_TIMEOUT=30
AI_ENABLE_THINKING=true

AGENT_ENABLE_TOOLS=true
AGENT_MAX_TOOL_ROUNDS=3
RAG_ENABLE_TOOL=false
RAG_COLLECTION_NAME=physics_knowledge_v2
RAG_RETRIEVAL_MODE=hybrid_rerank
RAG_PARENT_CHUNK_SIZE=1200
RAG_CHILD_CHUNK_SIZE=350
RAG_CHILD_CHUNK_OVERLAP=60
RAG_MODEL_MAX_LENGTH=1024
RAG_EMBED_BATCH_SIZE=4
RAG_DENSE_CANDIDATES=24
RAG_SPARSE_CANDIDATES=24
RAG_FUSION_CANDIDATES=20
RAG_RERANK_ENABLED=true
RAG_RERANK_THRESHOLD=0.05
RAG_TOP_K=6
RAG_MAX_CONCURRENT_SEARCHES=2
AI_MAX_CONCURRENT_REQUESTS=16
AI_MAX_CONCURRENT_REQUESTS_PER_SESSION=1
AI_MAX_REQUESTS_PER_MINUTE_PER_SESSION=20

# A separate AI server can call the public same-origin compute proxy.
COMPUTE_SERVICE_URL=http://127.0.0.1:8000

DATA_DIR=/var/lib/guidelab-ai/data
UPLOADS_DIR=/var/lib/guidelab-ai/uploads
KNOWLEDGE_BASE_DIR=/var/lib/guidelab-ai/knowledge_base
RAG_RAW_DIR=/var/lib/guidelab-ai/knowledge_base/raw_docs
RAG_PARSED_DIR=/var/lib/guidelab-ai/knowledge_base/parsed_docs
RAG_META_DIR=/var/lib/guidelab-ai/knowledge_base/experiment_meta
RAG_VECTOR_DIR=/var/lib/guidelab-ai/knowledge_base/vector_store
LOG_DIR=/var/log/guidelab-ai
LOG_FILE=/var/log/guidelab-ai/ai.log

CORS_ORIGINS=["https://ruixi.tech","https://www.ruixi.tech"]
CORS_ALLOW_CREDENTIALS=true
