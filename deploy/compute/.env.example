# Compute API (plotting + PySR)
DEBUG=false
COMPUTE_SERVICE_HOST=127.0.0.1
COMPUTE_SERVICE_PORT=8000

# 必须与 AI 服务完全一致。生成：openssl rand -hex 32
CLASSROOM_SESSION_SECRET=
CLASSROOM_SESSION_COOKIE_SECURE=true
CLASSROOM_SESSION_COOKIE_SAMESITE=lax

# 16-core / 32-GB balanced profile: 4 jobs x 3 Julia cores = 12 cores.
PYSR_MAX_CONCURRENT_TASKS=4
PYSR_PROCS_PER_TASK=3
PYSR_POPULATIONS_PER_TASK=9
PYSR_PARALLELISM=multithreading
PYSR_MAX_QUEUED_TASKS=120
PYSR_MAX_RUNNING_TASKS_PER_SESSION=1
PYSR_MAX_QUEUED_TASKS_PER_SESSION=2
PYSR_TASK_TIMEOUT_SECONDS=1800
PYSR_TASK_RETENTION_SECONDS=21600

PYSR_MAX_NITERATIONS=300
PYSR_MAX_POPULATION_SIZE=60
PYSR_MAX_EXPRESSION_SIZE=40
PYSR_MAX_BATCH_SIZE=1000

# Avoid nested BLAS thread pools in each isolated worker.
JULIA_NUM_THREADS=3
OMP_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1
MKL_NUM_THREADS=1

MAX_FILE_SIZE=10485760
DATA_DIR=/var/lib/guidelab/data
UPLOADS_DIR=/var/lib/guidelab/uploads
OUTPUTS_DIR=/var/lib/guidelab/outputs
PLOTS_DIR=/var/lib/guidelab/outputs/plots
PYSR_OUTPUT_DIR=/var/lib/guidelab/pysr
PYSR_PLOTS_DIR=/var/lib/guidelab/pysr/plots
LOG_DIR=/var/log/guidelab
LOG_FILE=/var/log/guidelab/compute.log

CORS_ORIGINS=["https://ruixi.tech","https://www.ruixi.tech"]
CORS_ALLOW_CREDENTIALS=true
